# Node.js modules (when running in Node)
from node:fs import readFile, writeFile, readdir
from node:path import join, dirname, basename
from node:child_process import exec, spawn
from node:crypto import createHash, randomBytes

# File system operations
async def read_json_file(filepath: str) -> dict:
    content = await readFile(filepath, "utf-8")
    return json.parse(content)

async def write_json_file(filepath: str, data: dict):
    content = json.stringify(data, indent=2)
    await writeFile(filepath, content)

async def list_directory(dirpath: str) -> list[str]:
    entries = await readdir(dirpath, {"withFileTypes": True})
    return [
        {"name": e.name, "isDirectory": e.isDirectory()}
        for e in entries
    ]

# Crypto operations
def hash_password(password: str, salt: str = None) -> dict:
    if salt is None:
        salt = randomBytes(16).toString("hex")

    hash_obj = createHash("sha256")
    hash_obj.update(password + salt)
    hash_value = hash_obj.digest("hex")

    return {"hash": hash_value, "salt": salt}

def verify_password(password: str, hash_value: str, salt: str) -> bool:
    result = hash_password(password, salt)
    return result["hash"] == hash_value

