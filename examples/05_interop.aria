# Using NumPy for numerical operations
def analyze_data(data: list[float]) -> dict:
    arr = np.array(data)
    return {
        "mean": np.mean(arr),
        "std": np.std(arr),
        "min": np.min(arr),
        "max": np.max(arr),
        "median": np.median(arr)
    }

# Using Pandas for data analysis
def process_csv(filename: str) -> dict:
    df = pd.read_csv(filename)

    # All Pandas operations work seamlessly
    summary = df.describe()
    grouped = df.groupby("category").agg({"value": "sum"})

    return {
        "rows": len(df),
        "columns": list(df.columns),
        "summary": summary.to_dict(),
        "by_category": grouped.to_dict()
    }

# Using SQLAlchemy
from python:sqlalchemy.orm import sessionmaker, declarative_base

Base = declarative_base()

class UserModel(Base):
    __tablename__ = "users"

    id = Column(Integer, primary_key=True)
    name = Column(String(100))
    email = Column(String(100), unique=True)

engine = create_engine("sqlite:///app.db")
Session = sessionmaker(bind=engine)

def get_all_users() -> list[dict]:
    session = Session()
    try:
        users = session.query(UserModel).all()
        return [{"id": u.id, "name": u.name, "email": u.email} for u in users]
    finally:
        session.close()

