# ====================
# PRACTICAL EXAMPLE: DATA PIPELINE
# ====================

async def data_pipeline():
    """
    A complete data pipeline showing Python and JS interop.
    Fetches data, processes with Pandas/NumPy, validates with Zod.
    """

    # Fetch data using Axios (JS)
    print("Fetching data...")
    response = await axios.get("https://api.example.com/data")
    raw_data = response.data

    # Validate schema using Zod (JS)
    DataSchema = zod.array(zod.object({
        id: zod.number(),
        value: zod.number(),
        category: zod.string()
    }))

    print("Validating data...")
    validated = DataSchema.parse(raw_data)

    # Convert to Pandas DataFrame (Python)
    print("Processing with Pandas...")
    df = pd.DataFrame(validated)

    # Numerical analysis with NumPy (Python)
    values = np.array(df["value"])
    stats = {
        "mean": float(np.mean(values)),
        "std": float(np.std(values)),
        "sum": float(np.sum(values))
    }

    # Group and aggregate with Pandas
    by_category = df.groupby("category").agg({
        "value": ["sum", "mean", "count"]
    }).to_dict()

    # Format dates with date-fns (JS)
    timestamp = formatDate(datetime.now(), "yyyy-MM-dd HH:mm:ss")

    # Build result using Lodash (JS)
    result = merge({}, stats, {
        "by_category": by_category,
        "processed_at": timestamp,
        "record_count": len(df)
    })

    return result

