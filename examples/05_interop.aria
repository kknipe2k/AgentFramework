# Using Axios for HTTP
async def fetch_github_user(username: str) -> dict:
    response = await axios.get(f"https://api.github.com/users/{username}")
    return response.data

# Using date-fns for date manipulation
def format_timestamp(iso_string: str) -> str:
    date = parseISO(iso_string)
    return formatDate(date, "MMMM do, yyyy 'at' h:mm a")

def get_next_week() -> list[str]:
    today = datetime.now()
    return [
        formatDate(addDays(today, i), "yyyy-MM-dd")
        for i in range(7)
    ]

# Using Zod for validation
UserSchema = zod.object({
    name: zod.string().min(2).max(100),
    email: zod.string().email(),
    age: zod.number().int().positive().optional()
})

def validate_user(data: dict) -> dict:
    try:
        validated = UserSchema.parse(data)
        return {"success": True, "data": validated}
    except zod.ZodError as e:
        return {"success": False, "errors": e.errors}

