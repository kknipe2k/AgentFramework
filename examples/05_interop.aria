# C/C++ via FFI
from aria.ffi import load_library, c_int, c_char_p, c_void_p

# Load a shared library
lib = load_library("./libexample.so")

# Define function signatures
lib.add_numbers.argtypes = [c_int, c_int]
lib.add_numbers.restype = c_int

lib.process_string.argtypes = [c_char_p]
lib.process_string.restype = c_char_p

# Call native functions
result = lib.add_numbers(5, 3)  # Returns 8
processed = lib.process_string(b"hello")

# Rust crate integration
from aria.rust import import_crate

# Import a Rust crate compiled to WASM or native
crypto_crate = import_crate("ring")

def secure_hash(data: bytes) -> bytes:
    return crypto_crate.digest.sha256(data)

# ====================
# ENTRY POINT
# ====================

async def main():
    # Demonstrate Python interop
    print("=== Python Interop ===")
    data = [1.5, 2.3, 4.1, 3.7, 2.8]
    stats = analyze_data(data)
    print(f"Statistics: {stats}")

    # Demonstrate JavaScript interop
    print("\n=== JavaScript Interop ===")
    dates = get_next_week()
    print(f"Next 7 days: {dates}")

    validation = validate_user({
        "name": "Alice",
        "email": "alice@example.com",
        "age": 30
    })
    print(f"Validation: {validation}")

    # Run data pipeline
    print("\n=== Data Pipeline ===")
    result = await data_pipeline()
    print(f"Pipeline result: {result}")

if __name__ == "__main__":
    run(main())
