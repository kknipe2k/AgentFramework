# Browser/DOM APIs (when running in browser)
from web:dom import document, window, localStorage
from web:fetch import fetch, Request, Headers
from web:websocket import WebSocket
from web:canvas import CanvasRenderingContext2D

# DOM manipulation
def setup_page():
    # Query elements
    header = document.querySelector("header")
    buttons = document.querySelectorAll(".btn")

    # Create elements
    div = document.createElement("div")
    div.className = "container"
    div.innerHTML = "<h1>Welcome</h1>"

    # Event listeners
    for btn in buttons:
        btn.addEventListener("click", (e) => {
            print(f"Button clicked: {e.target.textContent}")
        })

    # Local storage
    localStorage.setItem("theme", "dark")
    theme = localStorage.getItem("theme")

# Fetch API
async def fetch_data(url: str, options: dict = {}) -> dict:
    headers = Headers({
        "Content-Type": "application/json",
        "Authorization": f"Bearer {get_token()}"
    })

    request = Request(url, {
        "method": options.get("method", "GET"),
        "headers": headers,
        "body": json.stringify(options.get("body")) if options.get("body") else None
    })

    response = await fetch(request)

    if not response.ok:
        raise HttpError(response.status, await response.text())

    return await response.json()

# WebSocket client
class RealtimeClient:
    def __init__(self, url: str):
        self.url = url
        self.socket = None
        self.handlers = {}

    def connect(self):
        self.socket = WebSocket(self.url)

        self.socket.onopen = () => {
            print("Connected to server")
            self.emit("connected", {})
        }

        self.socket.onmessage = (event) => {
            data = json.parse(event.data)
            event_type = data.get("type")
            if event_type in self.handlers:
                self.handlers[event_type](data.get("payload"))
        }

        self.socket.onclose = () => {
            print("Disconnected from server")
            self.emit("disconnected", {})
        }

    def on(self, event_type: str, handler: fn):
        self.handlers[event_type] = handler

    def send(self, event_type: str, payload: dict):
        if self.socket and self.socket.readyState == WebSocket.OPEN:
            self.socket.send(json.stringify({
                "type": event_type,
                "payload": payload
            }))

