#!/bin/bash
# ARIA Pre-Push Hook
# Runs standard verification before allowing push
# Issue #21: Added configurable timeout support

# Exit on error, undefined vars, and pipeline failures
set -euo pipefail

ARIA_DIR="$(git rev-parse --show-toplevel)/.aria"
VERIFY_SCRIPT="$ARIA_DIR/verify-executor.sh"
COMMON_SCRIPT="$ARIA_DIR/common.sh"

# Source common.sh for timeout functions
# shellcheck source=/dev/null
source "$COMMON_SCRIPT" 2>/dev/null || true

# Colors (fallback if common.sh not loaded)
RED="${ARIA_RED:-\033[0;31m}"
GREEN="${ARIA_GREEN:-\033[0;32m}"
YELLOW="${ARIA_YELLOW:-\033[1;33m}"
NC="${ARIA_NC:-\033[0m}"

# Configurable hook timeout (default 180s for pre-push, can be overridden)
HOOK_TIMEOUT="${ARIA_PREPUSH_TIMEOUT:-180}"

echo -e "${YELLOW}ARIA: Running pre-push verification (timeout: ${HOOK_TIMEOUT}s)...${NC}"

# Check if ARIA is installed
if [[ ! -x "$VERIFY_SCRIPT" ]]; then
    echo -e "${YELLOW}ARIA not found, skipping verification${NC}"
    exit 0
fi

# Run standard verification with timeout
if type aria_run_with_timeout >/dev/null 2>&1; then
    aria_run_with_timeout "$HOOK_TIMEOUT" "pre_push_verification" "$VERIFY_SCRIPT" standard
    result=$?
elif command -v timeout >/dev/null 2>&1; then
    timeout "$HOOK_TIMEOUT" "$VERIFY_SCRIPT" standard
    result=$?
else
    "$VERIFY_SCRIPT" standard
    result=$?
fi

case $result in
    0)
        echo -e "${GREEN}ARIA: Pre-push verification passed${NC}"
        exit 0
        ;;
    124)
        echo -e "${RED}ARIA: Pre-push verification TIMED OUT after ${HOOK_TIMEOUT}s${NC}"
        echo ""
        echo "Options:"
        echo "  - Increase timeout: ARIA_PREPUSH_TIMEOUT=300 git push"
        echo "  - Bypass: git push --no-verify"
        exit 1
        ;;
    *)
        echo -e "${RED}ARIA: Pre-push verification failed${NC}"
        echo ""
        echo "Fix the issues above or bypass with: git push --no-verify"
        exit 1
        ;;
esac
