{
  "hooks": {
    "PreToolUse": [
      {
        "command": "bash .claude/hooks/aria-rails.sh PreToolUse \"$TOOL_NAME\" \"$TOOL_INPUT\"",
        "timeout": 5000
      }
    ],
    "PostToolUse": [
      {
        "command": "bash .claude/hooks/aria-rails.sh PostToolUse \"$TOOL_NAME\" \"$TOOL_INPUT\"",
        "timeout": 5000
      }
    ],
    "Stop": [
      {
        "command": "bash .claude/hooks/stop-verify.sh",
        "timeout": 30000
      }
    ]
  }
}
