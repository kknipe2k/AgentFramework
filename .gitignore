
# Rust build artifacts
/target/
# cargo-fuzz build artifacts and crash artifacts (fuzz/Cargo.lock is committed)
crates/*/fuzz/target/
crates/*/fuzz/artifacts/

# Node.js + frontend tooling (M02 Stage E)
/node_modules/
/dist/
/.vite/
/coverage/
/playwright-report/
/test-results/
.eslintcache

# ARIA runtime directories
.aria/checkpoints/
.aria/logs/
.aria/state/
__pycache__/

# ARIA Ralph runtime files
.aria/ralph/.story_failures
.aria/ralph/.story_failures.tmp.*

# Claude Code per-user settings (personal allowlist; not committed)
.claude/settings.local.json

# Tauri build-time generated schemas. Regenerated on every cargo build of
# src-tauri; not source-of-truth and platform-specific. M01 carry-forward —
# see docs/gap-analysis.md M01 entry Important "src-tauri/gen/schemas/
# should be gitignored to prevent future drift" (surfaced in PR #36).
src-tauri/gen/schemas/

# Environment variables — NEVER commit; .env.example is opt-in if needed
.env
.env.*
!.env.example

# OS-specific clutter
.DS_Store
Thumbs.db

# General logs
*.log

# Tauri development cache / dev-mode state
.tauri/

# Local CI-failure scratch file — carried over untracked across
# M06.A/B/C pre-flights; never a build artifact. Ignored at M06.C
# per the recurring pre-flight residue (CLAUDE.md §16 clean-tree gate).
ci-failures.txt

# cargo-mutants run artifacts + M08.7 ladder mutation/IRL scratch.
# `cargo mutants --in-place` (gotcha #92) writes mutants.out*/ and a
# scratch diff; the IRL watch of a built-in tool writes a test-read
# fixture and a per-rung scratch dir. Never build artifacts.
mutants.out*/
mutants.diff
test-read.txt
rung1/
